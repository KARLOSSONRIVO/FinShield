# ============================================================
#  FinShield ZAP Testing — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ── Target API ────────────────────────────────────────────────────────────────
# When running ZAP via Docker Desktop on Windows/Mac, use host.docker.internal
# instead of localhost so Docker can reach the host machine's server.
TARGET_URL=http://host.docker.internal:3000

# When running ZAP natively (not Docker), or Docker on Linux with --network host:
# TARGET_URL=http://localhost:3000

# ── SUPER_ADMIN credentials ────────────────────────────────────────────────────
# Used by run-zap.ps1/.sh to obtain a Bearer token automatically before ZAP starts.
ZAP_ADMIN_EMAIL=admin@finshield.com
ZAP_ADMIN_PASSWORD=Password123!

# ── Optional: additional role credentials for RBAC testing ────────────────────
# These are used by the multi-role script (run-zap-roles.ps1) to test A01.
ZAP_MANAGER_EMAIL=manager.hamish@finshield.com
ZAP_MANAGER_PASSWORD=Manager@123456

ZAP_USER_EMAIL=emp1.hamish@finshield.com
ZAP_USER_PASSWORD=Employee@123456

ZAP_AUDITOR_EMAIL=auditor.hamish@finshield.com
ZAP_AUDITOR_PASSWORD=Auditor@123456

ZAP_REGULATOR_EMAIL=regulator.hamish@finshield.com
ZAP_REGULATOR_PASSWORD=Password123!
