<?xml version="1.0" encoding="utf-8"?>
<!-- 
  This IIS configuration file is generated to satisfy ZAP security requirements.
  It disables directory browsing and removes the Server HTTP header.
-->
<configuration>
  <system.webServer>
    <!-- 1. Fix: Directory Browsing (Medium Risk) -->
    <directoryBrowse enabled="false" />

    <!-- 2. Fix: Server Leaks Version Information (Low Risk) -->
    <security>
      <requestFiltering removeServerHeader="true" />
    </security>

    <httpProtocol>
      <customHeaders>
        <!-- Ensure IIS does not inject its own X-Powered-By header -->
        <remove name="X-Powered-By" />
      </customHeaders>
    </httpProtocol>
  </system.webServer>
</configuration>
